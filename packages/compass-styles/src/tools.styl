@import ".variables";

.{$domain}-clearfix {
  zoom: 1;
  &::after {
    content: "";
    height: 0;
    visibility: hidden;
    display: block;
    clear: both;
  }
}

.{$domain}-selection
  ::selection
    color var(--cp-text-selection, #fff)
    background: var(--cp-text-selection-bg, #1890ff);

.{$domain}-scrollbar {
  ::-webkit-scrollbar {
    width: 5px;
    height: 5px;
    background: var(--cp-scrollbar, white)
  }

  ::-webkit-scrollbar-thumb {
    border-radius: 1em;
    background: var(--cp-scrollbar-thumb, rgba(0,0,0,0.40));
    width: 4px;
  }

  ::-webkit-scrollbar-track {
    border-radius: 1em;
    background: var(--cp-scrollbar-track, white);
  }
}
