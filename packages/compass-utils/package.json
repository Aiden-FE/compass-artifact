{
  "name": "@compass-aiden/utils",
  "version": "1.0.0",
  "description": "基础工具库",
  "private": true,
  "main": "dist/compass-utils.min.js",
  "module": "dist/compass-utils.es.min.js",
  "commonjs": "dist/compass-utils.cjs.min.js",
  "umd:main": "dist/compass-utils.umd.min.js",
  "jsdelivr": "dist/compass-utils.umd.min.js",
  "unpkg": "dist/compass-utils.umd.min.js",
  "types": "types/compass-utils.min.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "start": "npm run dev",
    "prepublish": "npm run lint && npm run docs",
    "build": "npm run clean && rollup -c config/rollup.config.prod.js",
    "dev": "rollup -w -c config/rollup.config.dev.js",
    "lint": "eslint --fix --ext .ts,.js src",
    "test": "jest --coverage",
    "docs": "typedoc --tsconfig tsconfig.json",
    "clean": "rimraf dist && rimraf types && rimraf coverage"
  },
  "author": "aiden_fe@outlook.com",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-json": "~4.1.0",
    "rollup-plugin-ts": "~3.0.1",
    "rollup-plugin-serve": "~1.1.0",
    "rollup": "~2.75.5",
    "@ampproject/rollup-plugin-closure-compiler": "~0.27.0",
    "rollup-plugin-terser": "~7.0.2",
    "rollup-plugin-cleanup": "~3.2.1",
    "rollup-plugin-summary": "~1.4.3",
    "@rollup/plugin-node-resolve": "~13.3.0",
    "@rollup/plugin-commonjs": "~22.0.0",
    "@zerollup/ts-transform-paths": "~1.7.18",
    "jest": "~28.1.0",
    "@types/jest": "~28.1.0",
    "ts-jest": "~28.0.3",
    "typescript": "~4.7.3",
    "eslint": "~8.17.0",
    "eslint-config-airbnb-base": "~15.0.0",
    "eslint-config-airbnb-typescript": "~17.0.0",
    "eslint-plugin-import": "~2.26.0",
    "@typescript-eslint/parser": "~5.27.0",
    "@typescript-eslint/eslint-plugin": "~5.27.0",
    "rimraf": "~3.0.2",
    "typedoc": "~0.22.17"
  }
}
